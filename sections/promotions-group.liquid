<h2 style="text-align:{{ section.settings.title_alignment }}">{{ section.settings.title }}</h2>

{% if settings.promotion_name.size > 0 %}
  <p>Active promation: {{ settings.promotion_name }}</p>
{% endif %}  

<div style="display: flex; justify-content: center; gap: 30px;">
  {% for block in section.blocks %}
    {% if block.type == 'promotion' %}
      <div style="display: flex; flex-direction: column; gap: 10px;">
        <h3 style="text-align: center">{{ block.settings.title }}</h3>
        {{ block.settings.image | image_url: width: 1000 | image_tag}}
      </div>
    {% endif %}
  {% endfor %}
</div>

{% schema %}
{
  "name": "Promotions Group",
  "tag": "section",
  "class": "my-wrapper-class",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Title Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    }
  ],
  "blocks": [
    {
      "type": "promotion",
      "name": "Promotion",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promotions Group"
    }
  ]
}
{% endschema %}
